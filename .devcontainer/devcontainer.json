{
  "name": "kgateway build-tools",
  // Official kgateway-dev container image
  // "image": "ghcr.io/kgateway-dev/devcontainer:kubeconeu-2026",
  // npolshakova's branch testing image 
  "image": "ghcr.io/npolshakova/devcontainer:kubeconeu-2026",
  // Use this for building before the image is published to GHCR
  // "build": {
  //   "dockerfile": "../tools/build-tools/Dockerfile",
  //   "context": ".."
  //  },
  "remoteEnv": {
    "USE_GKE_GCLOUD_AUTH_PLUGIN": "True",
    "BUILD_WITH_CONTAINER": "0",
    "CARGO_HOME": "/home/.cargo",
    "RUSTUP_HOME": "/home/.rustup",
    "DOCKER_API_VERSION": "1.43"
  },
  "features": {
    "ghcr.io/devcontainers/features/docker-outside-of-docker:1": {
	"version": "24.0", 
	"moby": true
    },
    "ghcr.io/mpriscella/features/kind:1": {}
  },
  "onCreateCommand": "for img in kgateway:v1.0.0-ci1 sds:v1.0.0-ci1 envoy-wrapper:v1.0.0-ci1 dummy-idp:0.0.1 extproc-server:0.0.1; do docker pull ghcr.io/npolshakova/$img || echo \"Warning: failed to pull $img, build it locally with: IMAGE_REGISTRY=ghcr.io/npolshakova VERSION=v1.0.0-ci1 make <target>-docker\"; done",
  "customizations": {
    "vscode": {
      "extensions": [
        "golang.go",
        "rust-lang.rust-analyzer",
        "eamodio.gitlens",
        "zxh404.vscode-proto3",
        "ms-azuretools.vscode-docker",
        "redhat.vscode-yaml",
        "IBM.output-colorizer"
      ],
      "settings": {
        "files.eol": "\n",
        "go.useLanguageServer": true,
        "go.lintTool": "golangci-lint"
      }
    }
  }
}
